# solr container only — do not add Rails app vars here.
# These are the standard Bitnami/Solr image environment variables.
# SOLR_ADMIN_USER / SOLR_ADMIN_PASSWORD are also used by the Solr healthcheck
# and must match the credentials in solr-setup/security.json.
SOLR_ENABLE_CLOUD_MODE=yes
SOLR_CLOUD_BOOTSTRAP=yes
ZK_HOST=zoo:2181
SOLR_ADMIN_USER=solr
SOLR_ADMIN_PASSWORD=SolrRocks
