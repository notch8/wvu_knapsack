# fcrepo container only — do not add Rails app vars here.
# JAVA_OPTS is fully expanded — no ${VAR} substitution.
# fcrepo.postgresql.username and fcrepo.postgresql.password must match
# POSTGRES_USER / POSTGRES_PASSWORD in .env.db.
JAVA_OPTS=-Xmx4g -Xms1g -Dfcrepo.modeshape.configuration="classpath:/config/jdbc-postgresql/repository.json" -Dfcrepo.postgresql.host=db -Dfcrepo.postgresql.username=postgres -Dfcrepo.postgresql.password=changeme -Dfcrepo.object.directory="/data/objects" -Dfcrepo.binary.directory="/data/fcrepo.binary.directory" -Djava.io.tmpdir="/data/tmp"
