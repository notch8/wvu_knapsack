# .env.production.example — copy to .env.production and fill in real values.
# .env.production is gitignored (.env.*). This example is committed as the reference.
#
# This is the ONLY env file read by docker-compose.production.yml.
# The .env symlink (-> hyrax-webapp/.env) is used by Stack Car local dev only.

# -----------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------
APP_NAME=wvu_knapsack
IN_DOCKER=true
RAILS_LOG_TO_STDOUT=true

# -----------------------------------------------------------------------
# Rails / Rack environment
# -----------------------------------------------------------------------
RAILS_ENV=production
PASSENGER_APP_ENV=production
RACK_ENV=production

# -----------------------------------------------------------------------
# Secrets — CHANGE THESE
# -----------------------------------------------------------------------
SECRET_KEY_BASE=changeme_generate_with_rails_secret
NEGATIVE_CAPTCHA_SECRET=changeme

# -----------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------
DB_ADAPTER=postgresql
DB_HOST=db
DB_PORT=5432
DB_NAME=hyku
DB_TEST_NAME=hyku_test
DB_USER=postgres
DB_PASSWORD=DatabaseFTW

# -----------------------------------------------------------------------
# Fedora (fcrepo)
# -----------------------------------------------------------------------
FCREPO_HOST=fcrepo
FCREPO_PORT=8080
FCREPO_REST_PATH=rest
FCREPO_BASE_PATH=/hykudemo
JAVA_OPTS=-Xmx4g -Xms1g

# -----------------------------------------------------------------------
# Solr
# -----------------------------------------------------------------------
SOLR_HOST=solr
SOLR_PORT=8983
SOLR_PATH=hydra_prod
SOLR_COLLECTION_NAME=hydra-development
SOLR_CONFIGSET_NAME=hyku
# App user credentials (set in solr9-setup/security.json)
SOLR_USER=hydra
SOLR_PASSWORD=m0Nif7rNp3ZpkiKN52NA
SOLR_URL=http://hydra:m0Nif7rNp3ZpkiKN52NA@solr:8983/solr/
# Solr admin credentials
SOLR_ADMIN_USER=solr
SOLR_ADMIN_PASSWORD=SolrRocks

# -----------------------------------------------------------------------
# Redis / Sidekiq
# -----------------------------------------------------------------------
REDIS_HOST=redis
REDIS_URL=redis://redis:6379/0
HYRAX_ACTIVE_JOB_QUEUE=good_job

# -----------------------------------------------------------------------
# Multitenancy & Routing
# Set these to match the actual server domain
# -----------------------------------------------------------------------
HYKU_MULTITENANT=true
HYKU_ROOT_HOST=lib.wvu.edu
HYKU_ADMIN_HOST=admin-wvu_knapsack.lib.wvu.edu
HYKU_DEFAULT_HOST=%{tenant}-wvu_knapsack.lib.wvu.edu
HYKU_ADMIN_ONLY_TENANT_CREATION=false
HYKU_BLOCK_VALKYRIE_REDIRECT=false
HYKU_RESTRICT_CREATE_AND_DESTROY_PERMISSIONS=true
HYKU_USER_DEFAULT_PASSWORD=password

# -----------------------------------------------------------------------
# Initial superadmin user (created by db:seed)
# -----------------------------------------------------------------------
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=changeme

# -----------------------------------------------------------------------
# First repository tenant (optional - leave unset to create via admin UI)
# The admin host itself (HYKU_ADMIN_HOST) is NOT a tenant; it routes to
# the superadmin interface. Set these to seed a first tenant on setup.
# -----------------------------------------------------------------------
# HYKU_FIRST_TENANT_NAME=wvu
# HYKU_FIRST_TENANT_CNAME=wvu-wvu_knapsack.lib.wvu.edu

# -----------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------
HYRAX_FLEXIBLE=false
HYRAX_VALKYRIE=true
VALKYRIE_TRANSITION=true
VALKYRIE_ID_TYPE=string
HYRAX_ANALYTICS=false

# -----------------------------------------------------------------------
# Fits
# -----------------------------------------------------------------------
CH12N_TOOL=fits_servlet
FITS_SERVLET_URL=http://fits:8080/fits

# -----------------------------------------------------------------------
# SSL — set DISABLE_FORCE_SSL=true only if running without an SSL-
# terminating reverse proxy (e.g. smoke-testing a bare build).
# Leave unset on the real VM where a proxy terminates SSL.
# -----------------------------------------------------------------------
# DISABLE_FORCE_SSL=true
